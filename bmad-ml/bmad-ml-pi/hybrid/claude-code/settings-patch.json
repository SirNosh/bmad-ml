{
  "permissions": {
    "allow": [
      "Bash(node .bmad-ml/dispatch-pi.mjs:*)",
      "Bash(mkdir -p .bmad-ml/tmp:*)",
      "Read(.bmad-ml/**)",
      "Read(_bmad/**)"
    ]
  },
  "hooks": {
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/subagent-log.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/subagent-log.sh"
          }
        ]
      }
    ]
  }
}
